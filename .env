# =============================================================================
# BrickLink API Credentials
# =============================================================================
# Get these from: https://www.bricklink.com/v2/api/register_consumer.page
#
# IMPORTANT: The Python fig_finder and the Node.js report scripts use
# different variable names for the same credentials. Set both sections below.

# --- Node.js report scripts (values must be wrapped in single quotes) ---
CONSUMER_KEY = ''
CONSUMER_SECRET = ''
ACCESS_TOKEN = ''
TOKEN_SECRET = ''

# Your BrickLink store/seller username (used by report scripts to filter sales)
STORE_NAME = 'maximeferland'

# --- Python fig_finder (same values, no quotes) ---
BRICKLINK_CONSUMER_KEY=
BRICKLINK_CONSUMER_SECRET=
BRICKLINK_ACCESS_TOKEN=
BRICKLINK_TOKEN_SECRET=

# =============================================================================
# Optional Settings (Python fig_finder)
# =============================================================================
BRICKLINK_BASE_URL=https://api.bricklink.com/api/store/v1
BRICKLINK_TIMEOUT=10

# Cache Settings
CACHE_ENABLED=true
CACHE_DIR=
CACHE_TTL=86400

# Performance
MAX_CONCURRENT_REQUESTS=5
